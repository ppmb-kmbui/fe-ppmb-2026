# Base URL the browser uses to call the API. Use "/api/v1" to route through
# the Next.js rewrite proxy defined in next.config.ts (recommended - keeps
# the request same-origin so the backend's httpOnly auth cookie works and
# CORS never applies).
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Server-side only: where the Next.js rewrite proxy forwards /api/v1/* to.
# Point this at the backend (be-ppmb-2026) dev server or deployment URL.
API_PROXY_TARGET=http://localhost:4000

# Cloudinary unsigned upload, used to host the signup profile photo since the
# backend only accepts imgUrl as a string URL (no file upload endpoint).
# Both values are public by design (unsigned upload preset, no API secret).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
